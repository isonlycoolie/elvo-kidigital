# ELVO Identity OTP providers
EMAIL_PROVIDER_HOST=smtp.example.com
EMAIL_PROVIDER_PORT=587
EMAIL_PROVIDER_USERNAME=replace_with_email_username
EMAIL_PROVIDER_PASSWORD=replace_with_email_password
EMAIL_PROVIDER_FROM=no-reply@elvo.example
EMAIL_PROVIDER_SMTP_AUTH=true
EMAIL_PROVIDER_SMTP_STARTTLS=true

SMS_PROVIDER_BASE_URL=https://sms-provider.example.com
SMS_PROVIDER_API_KEY=replace_with_sms_api_key
SMS_PROVIDER_SECRET=replace_with_sms_secret
SMS_PROVIDER_SENDER_ID=ELVO

# OTP security settings
ELVO_OTP_HASH_PEPPER=replace_with_long_random_pepper
ELVO_OTP_TTL_MINUTES=5
ELVO_OTP_MAX_ATTEMPTS=5
ELVO_OTP_MAX_RESENDS_PER_WINDOW=3
ELVO_OTP_RESEND_WINDOW_MINUTES=15
ELVO_OTP_RESEND_COOLDOWN_SECONDS=60
ELVO_OTP_VERIFY_IP_MAX=10
ELVO_OTP_VERIFY_IP_WINDOW_MINUTES=15
ELVO_OTP_SEND_IP_MAX=20
ELVO_OTP_SEND_IP_WINDOW_MINUTES=60
ELVO_OTP_SEND_DEVICE_MAX=10
ELVO_OTP_SEND_DEVICE_WINDOW_MINUTES=60
ELVO_OTP_RATE_LIMIT_KEY_PREFIX=elvo:otp:rate:

# Existing identity service essentials
ELVO_DB_HOST=localhost
ELVO_DB_PORT=5432
ELVO_DB_NAME=elvo_identity
ELVO_DB_USER=elvo
ELVO_DB_PASSWORD=elvo
ELVO_REDIS_HOST=localhost
ELVO_REDIS_PORT=6379
ELVO_RABBITMQ_HOST=localhost
ELVO_RABBITMQ_PORT=5672
ELVO_RABBITMQ_USER=guest
ELVO_RABBITMQ_PASSWORD=guest
