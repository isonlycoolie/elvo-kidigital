# Shared infrastructure variables loaded first (Docker runtime)
# Do not place service-owned DB credentials in this file.
SPRING_PROFILES_ACTIVE=dev

# Shared Redis (single container)
ELVO_REDIS_HOST=redis
ELVO_REDIS_PORT=6379
ELVO_REDIS_TIMEOUT_MS=5000

# Shared RabbitMQ (single container)
ELVO_RABBITMQ_HOST=rabbitmq
ELVO_RABBITMQ_PORT=5672
ELVO_RABBITMQ_USER=guest
ELVO_RABBITMQ_USERNAME=guest
ELVO_RABBITMQ_PASSWORD=guest
ELVO_RABBITMQ_VHOST=/

# Shared logging defaults
ELVO_LOG_LEVEL_ROOT=INFO
ELVO_LOG_LEVEL_APP=INFO

# Local Docker: disable TLS on infra (no TLS termination in compose)
ELVO_DB_SSL_ENABLED=false
ELVO_REDIS_SSL_ENABLED=false
ELVO_RABBITMQ_SSL_ENABLED=false

# Shared internal service JWT (wallet + account-mgmt internal APIs)
ELVO_INTERNAL_JWT_SECRET=wallet-internal-jwt-secret-local-at-least-32-chars
ELVO_INTERNAL_JWT_ISSUER=elvo-wallet-service-internal-dev
ELVO_INTERNAL_JWT_AUDIENCE=elvo-wallet-service-internal-dev

# Inter-service URLs (base = scheme + host + port only)
ELVO_WALLET_BASE_URL=http://elvo-wallet-service:8082
ELVO_WALLET_PROVISIONING_BASE_URL=http://elvo-wallet-service:8082
ELVO_ACCOUNT_MANAGEMENT_INTERNAL_BASE_URL=http://elvo-account-management-service:8084/api/v1/internal/accounts
ELVO_ACCOUNT_READ_BASE_URL=http://elvo-account-management-service:8084
ELVO_NOTIFICATION_BASE_URL=http://elvo-notification-service:8085

# Wallet client TLS enforcement (disable for local Docker)
ELVO_IDENTITY_TLS_ENFORCE_HTTPS=false
ELVO_IDENTITY_TLS_ENFORCE_MTLS=false

# Shared Sentry runtime wiring (optional for local)
ELVO_RUNTIME_SENTRY_DSN=
ELVO_RUNTIME_SENTRY_ENVIRONMENT=local
ELVO_RUNTIME_SENTRY_TRACES_SAMPLE_RATE=0.0
ELVO_RUNTIME_SENTRY_SEND_DEFAULT_PII=false
ELVO_RUNTIME_SENTRY_PROBE_ENABLED=false
ELVO_RUNTIME_SENTRY_PROBE_TOKEN=
ELVO_RUNTIME_SENTRY_ENABLED_BILLING=false
ELVO_RUNTIME_SENTRY_RELEASE_IDENTITY=elvo-identity-service@local
ELVO_RUNTIME_SENTRY_RELEASE_WALLET=elvo-wallet-service@local
ELVO_RUNTIME_SENTRY_RELEASE_BILLING=elvo-billing-service@local
ELVO_RUNTIME_SENTRY_RELEASE_ACCOUNT=elvo-account-management-service@local