# Service-specific credentials loaded after .env.shared

# Service identity and port
SERVICE_NAME=elvo-wallet-service
ELVO_SERVICE_PORT=8082

# Service-owned database
ELVO_DB_HOST=wallet-db
ELVO_DB_PORT=5432
ELVO_DB_NAME=wallet_db
ELVO_DB_USER=wallet_user
ELVO_DB_PASSWORD=replace_with_wallet_db_password

# Security and JWT
ELVO_JWT_SECRET_REF=replace_with_wallet_jwt_secret
ELVO_INTERNAL_SERVICE_SECRET=replace_with_internal_service_secret

# External service URLs
ELVO_IDENTITY_INTERNAL_BASE_URL=https://elvo-identity-service:8081/internal

# Logging and feature flags
ELVO_SANCTIONS_SCREENING_ENABLED=true