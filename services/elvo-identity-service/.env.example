# Service-specific credentials loaded after .env.shared

# Service identity and port
SERVICE_NAME=elvo-identity-service
ELVO_SERVICE_PORT=8081

# Service-owned database
ELVO_DB_HOST=identity-db
ELVO_DB_PORT=5432
ELVO_DB_NAME=identity_db
ELVO_DB_USER=identity_user
ELVO_DB_PASSWORD=replace_with_identity_db_password

# Security and JWT
ELVO_JWT_SECRET_REF=replace_with_identity_jwt_secret
ELVO_INTERNAL_SERVICE_SECRET=replace_with_internal_service_secret

# Identity OTP and communication secrets
ELVO_OTP_HASH_PEPPER=replace_with_identity_otp_pepper
ELVO_VERIFICATION_TOKEN_TTL_MINUTES=10
EMAIL_PROVIDER_HOST=smtp.example.com
EMAIL_PROVIDER_PORT=587
EMAIL_PROVIDER_USERNAME=replace_with_email_username
EMAIL_PROVIDER_PASSWORD=replace_with_email_password
EMAIL_PROVIDER_FROM=no-reply@elvo.example
SMS_PROVIDER_BASE_URL=https://sms-provider.example.com
SMS_PROVIDER_API_KEY=replace_with_sms_api_key
SMS_PROVIDER_SECRET=replace_with_sms_secret
SMS_PROVIDER_SENDER_ID=ELVO

# External service URLs
ELVO_WALLET_PROVISIONING_BASE_URL=http://elvo-wallet-service:8082/internal
ELVO_PROFILE_PROVISIONING_BASE_URL=http://elvo-web-dashboard-service:8086/internal

# Logging and feature flags
ELVO_VALIDATE_REQUIRED_ENV=true