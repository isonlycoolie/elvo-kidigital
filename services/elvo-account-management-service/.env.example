# Service-specific credentials loaded after .env.shared

# Service identity and port
SERVICE_NAME=elvo-account-management-service
ELVO_SERVICE_PORT=8084

# Service-owned database
ELVO_DB_HOST=account-db
ELVO_DB_PORT=5432
ELVO_DB_NAME=account_db
ELVO_DB_USER=account_user
ELVO_DB_PASSWORD=replace_with_account_db_password

# Legacy compatibility overrides (optional)
DB_URL=jdbc:postgresql://account-db:5432/account_db
DB_USER=account_user
DB_PASS=replace_with_account_db_password

# Service security and secrets
ELVO_INTERNAL_SERVICE_SECRET=replace_with_internal_service_secret

# Logging and feature flags
ELVO_LOG_LEVEL_APP=INFO
