# Service-specific credentials loaded after .env.shared

# Service identity and port
SERVICE_NAME=elvo-billing-service
ELVO_SERVICE_PORT=8083

# Service-owned database
ELVO_DB_HOST=billing-db
ELVO_DB_PORT=5432
ELVO_DB_NAME=billing_db
ELVO_DB_USER=billing_user
ELVO_DB_PASSWORD=replace_with_billing_db_password

# Security and JWT
ELVO_JWT_SECRET_REF=replace_with_billing_jwt_secret
ELVO_INTERNAL_SERVICE_SECRET=replace_with_internal_service_secret

# External service URLs (base = scheme + host + port only)
ELVO_WALLET_BASE_URL=http://elvo-wallet-service:8082
ELVO_IDENTITY_INTERNAL_BASE_URL=http://elvo-identity-service:8081

# Logging and feature flags
ELVO_LOG_LEVEL_BILLING=INFO
ELVO_BILLING_MOCK_ADAPTER_ENABLED=false