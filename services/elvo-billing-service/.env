# Service-specific credentials loaded after .env.shared
BILLING_DB_URL=jdbc:postgresql://localhost:5432/billing
BILLING_DB_USER=elvo
BILLING_DB_PASSWORD=replace_with_elvo-billing-service_db_password
RABBITMQ_URL=amqp://localhost:5672
LOG_LEVEL=INFO
ADAPTER_CONFIG=mock
ELVO_CORRELATION_ID_HEADER=X-Correlation-Id
ELVO_REQUEST_ID_HEADER=X-Request-Id
ELVO_IDEMPOTENCY_KEY_HEADER=Idempotency-Key

ELVO_DB_HOST=localhost
ELVO_DB_PORT=5432
ELVO_DB_NAME=billing
ELVO_DB_USER=elvo
ELVO_DB_PASSWORD=replace_with_elvo-billing-service_db_password
ELVO_JWT_SECRET_REF=replace_with_elvo-billing-service_jwt_secret
ELVO_SERVICE_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/billing
DB_USER=elvo
DB_PASS=replace_with_elvo-billing-service_db_password
ELVO_LOG_LEVEL_ROOT=INFO
ELVO_LOG_LEVEL_BILLING=INFO
ELVO_INTERNAL_SERVICE_SECRET=sm://elvo-internal-service-secret